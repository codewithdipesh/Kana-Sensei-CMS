rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Require authentication for all reads/writes by default
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Example: Admin-only collection pattern (server-side check recommended)
    // Use custom claims (isAdmin) set via firebase-admin on trusted servers.
    // match /admin/{doc=**} {
    //   allow read, write: if request.auth != null && request.auth.token.isAdmin == true;
    // }
  }
}
